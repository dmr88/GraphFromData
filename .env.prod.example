# Скопируйте в .env и заполните своими значениями.
# Файл .env не должен попадать в git (он уже в .gitignore по шаблону .env*).

# Пароли БД
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_STRONG
DB_PASSWORD=CHANGE_ME_USER_PASSWORD_STRONG

# Учётная запись администратора (создаётся через `docker compose --profile setup run --rm admin-setup`)
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD_STRONG
